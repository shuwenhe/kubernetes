# 查看所有的资源信息
kubectl get all
kubectl get all  --all-namespaces

# 查看node节点列表
kubectl get node
kubectl get nodes
kubectl get nodes -o wide

# 查看pod列表
kubectl get po
kubectl get pods
# 查看pod详细信息，也就是可以查看pod具体运行在哪个节点上（ip地址信息）
kubectl get pods -o wide

# 查看服务的详细信息，显示了服务名称，类型，集群ip，端口，时间等信息
kubectl get svc

# 查看命名空间
kubectl get ns
kubectl get cs